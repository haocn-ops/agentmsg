# Environment variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://agentmsg:agentmsg@localhost:5432/agentmsg?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10

# JWT Authentication
JWT_SECRET=change-me-in-production-use-strong-secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# API Gateway
API_GATEWAY_PORT=8080
API_GATEWAY_READ_TIMEOUT=30s
API_GATEWAY_WRITE_TIMEOUT=30s
API_GATEWAY_IDLE_TIMEOUT=120s

# Message Engine
MESSAGE_ENGINE_PORT=8081
MESSAGE_ENGINE_WORKER_COUNT=16
MESSAGE_ENGINE_BATCH_SIZE=100
MESSAGE_ENGINE_FLUSH_INTERVAL=100ms

# WebSocket
WS_MAX_CONNECTIONS=100000
WS_PING_INTERVAL=30s
WS_PONG_TIMEOUT=10s

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST=100

# Message Settings
MESSAGE_MAX_SIZE=1048576
MESSAGE_RETENTION_DAYS=30
MESSAGE_DLQ_RETENTION_DAYS=7

# TLS (for production)
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Feature Flags
FEATURE_CAPABILITY_DISCOVERY=true
FEATURE_EXACTLY_ONCE=false
FEATURE_MULTI_TENANT=true

# Multi-tenancy
DEFAULT_TENANT_LIMIT_MESSAGES=1000000
DEFAULT_TENANT_LIMIT_AGENTS=100
DEFAULT_TENANT_SLA_PERCENT=99.9

# SSO (for enterprise)
SSO_ENABLED=false
SSO_PROVIDER=okta
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_ISSUER_URL=

# AWS (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=messages
